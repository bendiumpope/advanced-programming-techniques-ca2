# Copy to .env and set strong random values for production.
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-jwt
# Dev server port (default 5001)
# PORT=5001
# Profile picture max size in bytes (default 2 MiB)
# MAX_AVATAR_BYTES=2097152
# Optional override (default: sqlite in backend/instance/app.db)
# DATABASE_URL=sqlite:////absolute/path/to/app.db
